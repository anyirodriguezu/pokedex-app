{
  "name": "pokedex-app",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "validate": "npm run typecheck && npm run lint && npm run test",
    "doctor": "npx expo-doctor",
    "deps:check": "expo install --check",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:prod": "eas build --platform ios --profile production",
    "build:all": "eas build --platform all --profile production",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "submit:all": "eas submit --platform all",
    "update": "eas update --auto",
    "update:preview": "eas update --branch preview",
    "update:prod": "eas update --branch production"
  },
  "dependencies": {
    "@hookform/resolvers": "3.9.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "7.18.5",
    "@react-navigation/native": "7.3.5",
    "@react-navigation/native-stack": "7.17.7",
    "@tamagui/config": "2.4.0",
    "@tanstack/react-query": "5.62.3",
    "expo": "54.0.34",
    "expo-haptics": "~15.0.8",
    "expo-status-bar": "3.0.9",
    "react": "19.1.0",
    "react-hook-form": "7.53.2",
    "react-native": "0.81.0",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0",
    "tamagui": "2.4.0",
    "yup": "1.4.0",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "19.1.10",
    "eslint": "9.39.4",
    "eslint-config-expo": "10.0.0",
    "jest": "29.7.0",
    "jest-expo": "54.0.17",
    "react-test-renderer": "^19.1.0",
    "test-renderer": "^1.2.0",
    "typescript": "5.5.4"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|tamagui|@tamagui/.*)"
    ],
    "moduleNameMapper": {
      "^tamagui$": "<rootDir>/src/__mocks__/tamagui.tsx",
      "^@tamagui/config(.*)$": "<rootDir>/src/__mocks__/@tamagui/config.ts",
      "^@react-native-async-storage/async-storage$": "@react-native-async-storage/async-storage/jest/async-storage-mock"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/__tests__/**",
      "!src/**/*.test.{ts,tsx}",
      "!src/test-utils.tsx"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ]
  },
  "expo": {
    "install": {
      "exclude": [
        "expo",
        "react-native",
        "typescript"
      ]
    }
  }
}
